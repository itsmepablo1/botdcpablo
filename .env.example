# ============================================================
#  DISCORD BOT - ENVIRONMENT CONFIGURATION (TEMPLATE)
#  Salin file ini ke .env dan isi nilainya!
# ============================================================

# --- Discord Bot ---
DISCORD_TOKEN=your_bot_token_here

# --- Web Panel ---
PANEL_SECRET_KEY=changeme_random_secret_string
PANEL_USERNAME=admin
PANEL_PASSWORD=your_panel_password_here
PANEL_HOST=0.0.0.0
PANEL_PORT=8080

# --- Database ---
DATABASE_PATH=./data/bot.db

# --- FFmpeg (leave empty to use system default) ---
FFMPEG_PATH=ffmpeg

# --- YouTube Data API v3 (optional) ---
YOUTUBE_API_KEY=

# --- Background Defaults ---
BACKGROUNDS_PATH=./assets/backgrounds
